# 複製為 .env 並填入實際值。切勿將 .env 提交到版本控制。

# 資料庫（Supabase）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# JWT 認證（建議 32+ 字元隨機字串）
JWT_SECRET=your-secret-at-least-32-chars

# 前端網址（用於 CORS、Email 連結）
FRONTEND_URL=http://localhost:3000

# SMTP 郵件（通知功能）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_EMAIL=your@email.com
SMTP_PASSWORD=your-smtp-password

# Google Drive 整合（選填，啟用後教材/作業/批改檔案會存到 Drive）
# 若未設定，檔案會存到本機 uploads（Render 重啟後會消失）
# GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account",...}  # Service Account JSON 整段
# GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# 選填
NODE_ENV=development
PORT=3001
LEADERBOARD_ALWAYS_VISIBLE=false
